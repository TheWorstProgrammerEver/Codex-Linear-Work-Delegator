# Safe defaults. Put secrets in .env.local or a systemd EnvironmentFile.

CODEX_LINEAR_API_URL=https://api.linear.app/graphql
CODEX_LINEAR_AGENT_ID=daedalus
CODEX_LINEAR_AGENT_LABELS=agent:daedalus,agent:any

CODEX_LINEAR_READY_STATUS=Waiting For Agent
CODEX_LINEAR_RUNNING_STATUS=Agent In Progress
CODEX_LINEAR_BLOCKED_STATUS=Blocked
CODEX_LINEAR_REVIEW_STATUS=In Review

CODEX_LINEAR_DEFAULT_MODEL=gpt-5.5
CODEX_LINEAR_DEFAULT_SANDBOX=danger-full-access
CODEX_LINEAR_CODEX_BIN=codex
CODEX_LINEAR_CODEX_CWD=/home/daedalus

CODEX_LINEAR_STATE_DIR=/home/daedalus/.local/state/codex-linear-work-delegator
CODEX_LINEAR_WAIT_TIMEOUT_SECONDS=60
CODEX_LINEAR_LOCK_STALE_SECONDS=600
CODEX_LINEAR_FETCH_LIMIT=50

# Optional. Leave empty to search all visible teams.
CODEX_LINEAR_TEAM_KEY=

# Optional extra static args appended before the prompt.
CODEX_LINEAR_CODEX_EXTRA_ARGS=
